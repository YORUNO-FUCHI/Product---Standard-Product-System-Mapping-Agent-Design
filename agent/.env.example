# 复制为 .env 后填写。DeepSeek 只提供 chat 接口（无 embedding）。
DEEPSEEK_API_KEY=sk-你的key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 召回后端：memory（默认，纯 Python 现在就能跑）| pg（装 Docker 后切换）
RECALL_BACKEND=memory

# Embedding：hash（默认，零依赖占位）| st（本地 sentence-transformers，语义更好）
EMBEDDER=hash
EMBED_DIM=256
# ST 模型路径（不设则自动检测 agent/models/ 下的本地模型，或从 HuggingFace 下载）
# ST_MODEL=BAAI/bge-small-zh-v1.5
# 若想指定本地路径（免联网），设为模型目录的绝对路径：
# ST_MODEL=E:/cc switch/agent/models/bge-small-zh-v1.5

# 召回/精排参数
K_TRGM=20
K_VEC=20
K_RERANK=12

# 仅 RECALL_BACKEND=pg 时使用
PG_DSN=postgresql://postgres:postgres@localhost:5432/taxonomy

# 同义词反馈环：仅 RECALL_BACKEND=pg 时可写回 Postgres，不改 Excel
SYN_FEEDBACK_ENABLED=true
SYN_FEEDBACK_VEC_THRESHOLD=0.95
SYN_FEEDBACK_TRGM_THRESHOLD=0.0
SYN_FEEDBACK_AUTO_APPROVE=false

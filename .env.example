# 复制为 .env 后填写。DeepSeek 只提供 chat 接口（无 embedding）。
DEEPSEEK_API_KEY=sk-你的key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 召回后端：memory（默认，纯 Python 现在就能跑）| pg（装 Docker 后切换）
RECALL_BACKEND=memory

# Embedding：hash（默认，零依赖占位）| st（本地 sentence-transformers，语义更好）
EMBEDDER=hash
EMBED_DIM=256
# ST_MODEL=BAAI/bge-small-zh-v1.5

# 召回/精排参数
K_TRGM=20
K_VEC=20
K_RERANK=12

# 仅 RECALL_BACKEND=pg 时使用
PG_DSN=postgresql://postgres:postgres@localhost:5432/taxonomy
